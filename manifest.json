// ─── YouTube → Roblox Bridge ─── popup.js ────────────────────────────────

// ── DOM refs ──────────────────────────────────────────────────────────────
const enabledToggle   = document.getElementById("enabled-toggle");
const toggleLabel     = document.getElementById("toggle-label");
const thumb           = document.getElementById("thumb");
const trackTitle      = document.getElementById("track-title");
const trackChannel    = document.getElementById("track-channel");
const trackState      = document.getElementById("track-state");
const userTokenInput  = document.getElementById("user-token");
const serverUrlInput  = document.getElementById("server-url");
const saveBtn         = document.getElementById("save-btn");
const linkCodeSection = document.getElementById("link-code-section");
const linkCodeEl      = document.getElementById("link-code");
const statusDot       = document.getElementById("status-dot");
const statusText      = document.getElementById("status-text");

// ── Helpers ───────────────────────────────────────────────────────────────

const setStatus = (type, msg) => {
  statusDot.className = `status-dot ${type}`;
  statusText.textContent = msg;
};

const formatTime = (secs) => {
  if (!secs) return "";
  const m = Math.floor(secs / 60);
  const s = String(Math.floor(secs % 60)).padStart(2, "0");
  return `${m}:${s}`;
};

// ── Load saved settings ───────────────────────────────────────────────────

chrome.storage.sync.get(
  ["userToken", "serverUrl", "enabled", "nowPlaying"],
  ({ userToken, serverUrl, enabled, nowPlaying }) => {
    // Toggle
    const isEnabled = enabled !== false;
    enabledToggle.checked = isEnabled;
    toggleLabel.textContent = isEnabled ? "On" : "Off";

    // Fields
    if (userToken) userTokenInput.value = userToken;
    if (serverUrl) serverUrlInput.value = serverUrl;

    // Link code (derived from token — just the token itself for simplicity)
    if (userToken) {
      linkCodeSection.style.display = "flex";
      linkCodeEl.textContent = userToken;
      setStatus("ok", "Connected — token saved");
    } else {
      setStatus("warn", "Enter your token to get started");
    }

    // Now playing state
    if (nowPlaying) renderNowPlaying(nowPlaying);
  }
);

// ── Render now-playing card ───────────────────────────────────────────────

const renderNowPlaying = (data) => {
  if (!data || !data.videoId) return;

  trackTitle.textContent   = data.title   || "Unknown title";
  trackChannel.textContent = data.channel || "";

  if (data.thumbnail) {
    thumb.src = data.thumbnail;
    thumb.style.display = "block";
  }

  const pos      = formatTime(data.position);
  const dur      = formatTime(data.duration);
  const timeStr  = pos && dur ? ` · ${pos} / ${dur}` : "";

  if (data.paused) {
    trackState.textContent  = `Paused${timeStr}`;
    trackState.className    = "track-state state-paused";
  } else {
    trackState.textContent  = `Playing${timeStr}`;
    trackState.className    = "track-state state-playing";
  }
};

// ── Toggle handler ────────────────────────────────────────────────────────

enabledToggle.addEventListener("change", () => {
  const val = enabledToggle.checked;
  toggleLabel.textContent = val ? "On" : "Off";
  chrome.storage.sync.set({ enabled: val });
  setStatus(val ? "ok" : "", val ? "Syncing enabled" : "Syncing paused");
});

// ── Save button ───────────────────────────────────────────────────────────

saveBtn.addEventListener("click", () => {
  const token = userTokenInput.value.trim();
  const url   = serverUrlInput.value.trim();

  if (!token) {
    setStatus("error", "Token can't be empty");
    userTokenInput.focus();
    return;
  }

  chrome.storage.sync.set({ userToken: token, serverUrl: url || undefined }, () => {
    linkCodeSection.style.display = "flex";
    linkCodeEl.textContent = token;
    setStatus("ok", "Settings saved!");

    // Brief confirmation flash on button
    saveBtn.textContent = "Saved ✓";
    setTimeout(() => (saveBtn.textContent = "Save Settings"), 1500);
  });
});

// ── Listen for live updates from background ───────────────────────────────
// Background stores latest nowPlaying in chrome.storage.local so popup
// can always show the current state even without a live port.

chrome.storage.onChanged.addListener((changes, area) => {
  if (area === "local" && changes.nowPlaying) {
    renderNowPlaying(changes.nowPlaying.newValue);
  }
});

// Also pull latest from storage on open
chrome.storage.local.get(["nowPlaying"], ({ nowPlaying }) => {
  if (nowPlaying) renderNowPlaying(nowPlaying);
});
