{
  "manifest_version": 3,
  "name": "YouTube → Roblox Now Playing",
  "version": "1.0.0",
  "description": "Syncs your current YouTube video to your Roblox experience in real time.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "src/background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "src/popup.html",
    "default_title": "YT → Roblox"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
